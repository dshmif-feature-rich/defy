---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SpecialistSection from '../components/SpecialistSection.astro';
import home from '../content/pages/home.json';
import { site } from '../config/site';
---

<BaseLayout
  title="Home"
  description={home.description}
  currentPath="/"
  ogImage={`${site.url}/og-image.png`}
>
  <Hero />

  <section class="py-16 sm:py-20">
    <div class="container-defy max-w-4xl">
      {
        home.intro.map((paragraph) => (
          <p class="mb-6 text-lg leading-relaxed text-defy-charcoal/90 last:mb-0">
            {paragraph}
          </p>
        ))
      }
    </div>
  </section>

  <SpecialistSection {...home.specialist} />
</BaseLayout>