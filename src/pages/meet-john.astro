---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SubBanner from '../components/SubBanner.astro';
import meetJohn from '../content/pages/meet-john.json';
import { getImage } from '../lib/images';

const bannerImage = getImage(meetJohn.banner);
const profilePhoto = getImage('dr-a-629.jpg');
---

<BaseLayout title="Meet John" description={meetJohn.description} currentPath="/meet-john">
  <SubBanner
    title="Meet John"
    image={bannerImage}
    breadcrumbs={meetJohn.breadcrumbs}
  />

  <section class="py-16 sm:py-20">
    <div class="container-defy">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-2 lg:items-start">
        <div class="overflow-hidden">
          <Image
            src={profilePhoto}
            alt="Dr. John Apostolides"
            class="w-full object-cover"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            loading="lazy"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl text-defy-rose">{meetJohn.name}</h2>
          <p class="mt-2 text-sm font-medium tracking-wide text-defy-charcoal/70 uppercase">
            {meetJohn.role}
          </p>
          <div class="mt-6 space-y-6">
            {
              meetJohn.paragraphs.map((paragraph) => (
                <p class="leading-relaxed text-defy-charcoal/90">{paragraph}</p>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>