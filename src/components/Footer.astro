---
import { site, footerGuideLinks } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="bg-defy-dark text-white/80">
  <div class="container-defy py-12">
    <div class="grid gap-10 md:grid-cols-2">
      <div>
        <h5 class="mb-4 border-b border-defy-rose pb-2 font-serif text-lg tracking-widest text-defy-rose uppercase">
          Guide
        </h5>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          {
            footerGuideLinks.map((link) => (
              <li>
                {'external' in link && link.external ? (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transition-colors hover:text-defy-rose"
                  >
                    {link.label}
                    <span aria-hidden="true"> ↗</span>
                  </a>
                ) : (
                  <a
                    href={link.href}
                    class="transition-colors hover:text-defy-rose"
                  >
                    {link.label}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h5 class="mb-4 border-b border-defy-rose pb-2 font-serif text-lg tracking-widest text-defy-rose uppercase">
          Get In Touch
        </h5>
        <p class="mb-4 text-sm text-white/90">
          DEFY Plastic and Reconstructive Surgery
        </p>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href={site.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-start gap-2 transition-colors hover:text-defy-rose"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{site.address}</span>
            </a>
          </li>
          <li>
            <a
              href={`tel:${site.phoneTel}`}
              class="inline-flex items-center gap-2 transition-colors hover:text-defy-rose"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {site.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${site.email}`}
              class="inline-flex items-center gap-2 transition-colors hover:text-defy-rose"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {site.email}
            </a>
          </li>
          <li class="inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {site.hours}
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-4">
    <div class="container-defy">
      <p class="text-center text-xs text-white/50">
        Copyright &copy; {year} DefyPRS. All rights reserved.
      </p>
    </div>
  </div>
</footer>